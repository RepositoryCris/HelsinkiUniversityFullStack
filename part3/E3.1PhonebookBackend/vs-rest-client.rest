@baseUrl = http://localhost:3001

### ==================== GET REQUESTS ====================

### Get root endpoint
GET {{baseUrl}}
# Expected: 200 HTML response

### Get all persons
GET {{baseUrl}}/api/persons
# Expected: 200 JSON array

### Get info page
GET {{baseUrl}}/info
# Expected: 200 HTML

### Get person with valid Mongo ID
GET {{baseUrl}}/api/persons/69ba020a11a37853cfc836e2
# Expected: 200 JSON or 404 if doesn't exist

### Get person with non-existent ID
GET {{baseUrl}}/api/persons/999999999999999999999999
# Expected: 404 Not Found

### ==================== DELETE REQUESTS ====================

### Delete person with valid ID
DELETE {{baseUrl}}/api/persons/69bc4faf19d856efbeee1c68
# Expected: 204 No Content or 404 Not Found

### ==================== POST REQUESTS ====================

### [SUCCESS] Post a valid new person
POST {{baseUrl}}/api/persons
content-type: application/json

{
    "name": "Unique Test Person",
    "number": "09-1234567"
}
### Expected: 201 with new person object

### [ERROR] Post with invalid phone number (no dash)
POST {{baseUrl}}/api/persons
content-type: application/json

{
    "name": "Invalid Phone",
    "number": "091234567"
}
### Expected: 400 { "error": "091234567 is not a valid phone number!" }

### [ERROR] Post with invalid phone number (wrong format)
POST {{baseUrl}}/api/persons
content-type: application/json

{
    "name": "Invalid Phone 2",
    "number": "1-22-334455"
}
### Expected: 400 { "error": "1-22-334455 is not a valid phone number!" }

### [ERROR] Post with missing name
POST {{baseUrl}}/api/persons
content-type: application/json

{
    "number": "09-1234567"
}
### Expected: 400 { "error": "Name or number missing" }

### [ERROR] Post with missing number
POST {{baseUrl}}/api/persons
content-type: application/json

{
    "name": "Jane Doe"
}
### Expected: 400 { "error": "Name or number missing" }

### [ERROR] Post with empty name string
POST {{baseUrl}}/api/persons
content-type: application/json

{
    "name": "",
    "number": "09-1234567"
}
### Expected: 400 { "error": "Name or number missing" }

### [ERROR] Post with empty number string
POST {{baseUrl}}/api/persons
content-type: application/json

{
    "name": "John Smith",
    "number": ""
}
### Expected: 400 { "error": "Name or number missing" }

### [ERROR] Post with minLength < 3 in name
POST {{baseUrl}}/api/persons
content-type: application/json

{
    "name": "Jo",
    "number": "09-1234567"
}
### Expected: 400 { "error": "Name must be at least 3 characters long" }

### [SUCCESS] Post with duplicate name (exact case)
POST {{baseUrl}}/api/persons
content-type: application/json

{
    "name": "Unique Test Person",
    "number": "040-22334455"
}
### Expected: 400 { "error": "Name must be unique" }

### [SUCCESS] Post with duplicate name (case-insensitive)
POST {{baseUrl}}/api/persons
content-type: application/json

{
    "name": "unique test person",
    "number": "040-22334456"
}
### Expected: 400 { "error": "Name must be unique" }

### ==================== PUT REQUESTS ====================

### [SUCCESS] Put a valid number update
PUT {{baseUrl}}/api/persons/69bc504219d856efbeee1c76
content-type: application/json

{
    "number": "040-22334455"
}
### Expected: 200 JSON

### [ERROR] Put with invalid phone number
PUT {{baseUrl}}/api/persons/69bc504219d856efbeee1c76
content-type: application/json

{
    "number": "123456"
}
### Expected: 400 { "error": "123456 is not a valid phone number!" }

### [ERROR] Put with empty number string
PUT {{baseUrl}}/api/persons/69bc504219d856efbeee1c76
content-type: application/json

{
    "number": ""
}
### Expected: 400 { "error": "Name or number missing" }