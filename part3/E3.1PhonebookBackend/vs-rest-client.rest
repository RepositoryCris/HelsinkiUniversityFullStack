@baseUrl = http://localhost:3001

### ==================== GET REQUESTS ====================

### Get root endpoint
GET {{baseUrl}}
# Expected: 200 HTML response

### Get all persons
GET {{baseUrl}}/api/persons
# Expected: 200 JSON array

### Get info page
GET {{baseUrl}}/info
# Expected: 200 HTML

### Get person with ID 1 (if exists)
GET {{baseUrl}}/api/persons/1
# Expected: 200 JSON or 404 if doesn't exist

### Get person with non-existent ID
GET {{baseUrl}}/api/persons/99999
# Expected: 404 Not Found

### ==================== DELETE REQUESTS ====================

### Delete person with ID 1 (if exists)
DELETE {{baseUrl}}/api/persons/1
# Expected: 204 No Content or 404 Not Found

### ========= POST REQUESTS =========

### [SUCCESS] Post a valid new person
POST {{baseUrl}}/api/persons/
content-type: application/json

{
    "name": "Unique Test Person",
    "number": "7777777"
}
### Expected: 201 Created with new person object


### [ERROR] Post with missing name
POST {{baseUrl}}/api/persons/
content-type: application/json

{
    "number": "7777777"
}
### Expected: 400 { "error": "Name or number missing" }


### [ERROR] Post with missing number
POST {{baseUrl}}/api/persons/
content-type: application/json

{
    "name": "Jane Doe"
}
### Expected: 400 { "error": "Name or number missing" }


### [ERROR] Post with empty name string
POST {{baseUrl}}/api/persons/
content-type: application/json

{
    "name": "",
    "number": "7777777"
}
### Expected: 400 { "error": "Name or number missing" }


### [ERROR] Post with empty number string
POST {{baseUrl}}/api/persons/
content-type: application/json

{
    "name": "John Smith",
    "number": ""
}
### Expected: 400 { "error": "Name or number missing" }


### [ERROR] Post with duplicate name (exact match)
POST {{baseUrl}}/api/persons/
content-type: application/json

{
    "name": "Cristian Junior Developer",
    "number": "8888888"
}
### Expected: 400 { "error": "Name must be unique" }


### [ERROR] Post with duplicate name (case insensitive)
POST {{baseUrl}}/api/persons/
content-type: application/json

{
    "name": "cristian junior developer",
    "number": "9999999"
}
### Expected: 400 { "error": "Name must be unique" }