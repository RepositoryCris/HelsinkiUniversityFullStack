### ---------- END-TO-END WORKFLOW ----------

### 1. Register new user account
# Expected: 201 Created
POST {{baseurl}}/api/users
Content-Type: application/json

{
    "username": "alice",
    "name": "Alice Wonderland",
    "password": "alice123"
}

### 2. Authenticate new user
# @name loginAlice
# Expected: 200 OK
POST {{baseurl}}/api/login
Content-Type: application/json

{
    "username": "alice",
    "password": "alice123"
}

@aliceToken = {{loginAlice.response.body.token}}

### 3. Create blog as authenticated user
# @name aliceBlog
# Expected: 201 Created
# Success: Blog creator automatically assigned to Alice
POST {{baseurl}}/api/blogs
Authorization: Bearer {{aliceToken}}
Content-Type: application/json

{
    "title": "Alice's Blog",
    "author": "Alice",
    "url": "http://alice.com",
    "likes": 42
}

@aliceBlogId = {{aliceBlog.response.body.id}}

### 4. Verify blog includes creator information
# Expected: 200 OK
# Success: Blog object contains populated user field with Alice's data
GET {{baseurl}}/api/blogs

### 5. Update own blog
# Expected: 200 OK
PUT {{baseurl}}/api/blogs/{{aliceBlogId}}
Authorization: Bearer {{aliceToken}}
Content-Type: application/json

{
    "likes": 100
}

### 6. Retrieve updated blog to confirm changes
# Expected: 200 OK
GET {{baseurl}}/api/blogs/{{aliceBlogId}}

### 7. Delete own blog
# Expected: 204 No Content
DELETE {{baseurl}}/api/blogs/{{aliceBlogId}}
Authorization: Bearer {{aliceToken}}

### 8. Confirm blog removal
# Expected: 200 OK
# Success: Blog should no longer appear in collection
GET {{baseurl}}/api/blogs

### ---------- AUTHORIZATION & ACCESS CONTROL ----------

### 1. Register second user
# Expected: 201 Created
POST {{baseurl}}/api/users
Content-Type: application/json

{
    "username": "bob",
    "name": "Bob Builder",
    "password": "bob123"
}

### 2. Authenticate as second user
# @name loginBob
# Expected: 200 OK
POST {{baseurl}}/api/login
Content-Type: application/json

{
    "username": "bob",
    "password": "bob123"
}

@bobToken = {{loginBob.response.body.token}}

### 3. Create blog as second user
# @name bobBlog
# Expected: 201 Created
POST {{baseurl}}/api/blogs
Authorization: Bearer {{bobToken}}
Content-Type: application/json

{
    "title": "Bob's Blog",
    "author": "Bob",
    "url": "http://bob.com",
    "likes": 10
}

@bobBlogId = {{bobBlog.response.body.token}}

### 4. Attempt unauthorized deletion - different user (should fail)
# Expected: 401 Unauthorized
# Failure: Only the creator can delete this blog
DELETE {{baseurl}}/api/blogs/{{bobBlogId}}
Authorization: Bearer {{aliceToken}}

### 5. Authorized deletion - owner removes own blog (should succeed)
# Expected: 204 No Content
DELETE {{baseurl}}/api/blogs/{{bobBlogId}}
Authorization: Bearer {{bobToken}}

